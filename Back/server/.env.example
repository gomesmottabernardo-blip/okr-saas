# ── Banco de dados (Neon PostgreSQL) ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere com: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=troque-por-uma-string-aleatoria-de-64-bytes

# ── CORS ──────────────────────────────────────────────────────────────────────
# Em produção: URL exata do seu frontend na Vercel (sem barra final)
# Separe múltiplas origens com vírgula
ALLOWED_ORIGINS=https://seu-app.vercel.app

# ── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Porta (Render define automaticamente) ────────────────────────────────────
# PORT=4000
